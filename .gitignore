# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editors ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.orig

# ══════════════════════════════════════════════════════════════════════════════
# API — Python / FastAPI
# ══════════════════════════════════════════════════════════════════════════════

# Virtual environments
api/.venv/
api/venv/
api/env/

# Python cache
api/**/__pycache__/
api/**/*.py[cod]
api/**/*.pyo
api/.mypy_cache/
api/.ruff_cache/

# SQLite database files
api/*.db
api/*.db-shm
api/*.db-wal

# Uploaded PDFs (runtime data — not source code)
api/uploads/*
!api/uploads/.gitkeep

# Environment config (contains secrets in production)
api/.env

# Alembic autogenerated (keep versions/, ignore compiled)
api/alembic.ini.local

# Pytest / coverage
api/.pytest_cache/
api/htmlcov/
api/.coverage
api/coverage.xml

# Distribution / packaging
api/dist/
api/build/
api/*.egg-info/

# ══════════════════════════════════════════════════════════════════════════════
# View — React / Vite / Node
# ══════════════════════════════════════════════════════════════════════════════

# Dependencies (bare pattern matches node_modules/ at any depth)
node_modules/

# Build output
view/dist/
view/dist-ssr/

# Vite cache
view/.vite/

# TypeScript build info
view/*.tsbuildinfo

# Environment variables
view/.env
view/.env.local
view/.env.*.local

# Test output
view/coverage/

# Logs
view/npm-debug.log*
view/yarn-debug.log*
view/yarn-error.log*
view/.pnpm-debug.log*
